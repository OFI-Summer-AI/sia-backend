DJANGO_SETTINGS_MODULE=
DEBUG=
SECRET_KEY=
ALLOWED_HOSTS=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

GEMINI_API_KEY=
CORS_ALLOWED_ORIGINS=
SESSION_COOKIE_SECURE=
CSRF_COOKIE_SECURE=

FRONTEND_URL=http://localhost:3000

# Email — in development use the console backend (prints to terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production with SMTP:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=SIA <noreply@siasolutions.com>

# OIDC / OAuth 2.0 — required for agent SSO
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST match the OIDC_SIGNING_KEY configured in each agent (hr-agent, mark-agent)
OIDC_SIGNING_KEY=
# Public URL of this backend — used as the `iss` claim in id_tokens
OIDC_ISSUER=http://localhost:8000
